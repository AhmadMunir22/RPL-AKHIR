# ======================================================
# PadelBook — Environment Configuration Template
# Salin file ini menjadi .env dan isi sesuai server Anda
# ======================================================

APP_NAME=PadelBook
APP_ENV=production
APP_KEY=                          # Jalankan: php artisan key:generate
APP_DEBUG=false
APP_URL=https://domain-anda.com   # Ganti dengan domain hosting Anda

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─── DATABASE ─────────────────────────────────────────
# Untuk shared hosting (cPanel) gunakan MySQL:
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nama_database
DB_USERNAME=user_database
DB_PASSWORD=password_database

# Untuk SQLite (sederhana, tidak perlu server DB):
# DB_CONNECTION=sqlite
# (Buat file database/database.sqlite kosong, lalu jalankan php artisan migrate)

# ─── MIDTRANS ─────────────────────────────────────────
MIDTRANS_SERVER_KEY=             # Isi dari dashboard Midtrans
MIDTRANS_CLIENT_KEY=             # Isi dari dashboard Midtrans
MIDTRANS_IS_PRODUCTION=true      # Ganti ke true saat production

# ─── GOOGLE OAUTH ─────────────────────────────────────
GOOGLE_CLIENT_ID=                # Dari Google Cloud Console
GOOGLE_CLIENT_SECRET=            # Dari Google Cloud Console
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ─── EMAIL (SMTP) ─────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=                   # Email Gmail pengirim
MAIL_PASSWORD=                   # App Password Gmail (bukan password biasa)
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=               # Sama dengan MAIL_USERNAME
MAIL_FROM_NAME="${APP_NAME}"

# ─── CACHE & SESSION ──────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── WhatsApp (Dinonaktifkan) ─────────────────────────
KATA_AI_TOKEN=

# ─── AWS (Tidak digunakan) ────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
